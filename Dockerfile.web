# SparkBill - Web App Dockerfile (Next.js)
# For deploying the dashboard if NOT using Vercel

FROM node:20-slim

# Install openssl for Prisma compatibility (node:20-slim = Debian Bookworm with OpenSSL 3.x)
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install OpenSSL (required by Prisma query engine)
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# Copy Prisma schema first (needed by postinstall)
COPY package.json package-lock.json* ./
COPY prisma ./prisma

# Install dependencies (postinstall runs prisma generate)
RUN npm ci

# Copy source and build
COPY . .
RUN npm run build

ENV NODE_ENV=production
EXPOSE 3000

CMD ["npm", "start"]
