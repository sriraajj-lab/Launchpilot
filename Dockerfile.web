# LaunchPilot - Web App Dockerfile (Next.js)

FROM node:20-slim

# Install openssl for Prisma compatibility
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy Prisma schema first (needed by postinstall)
COPY package.json package-lock.json* ./
COPY prisma ./prisma

# Install dependencies (postinstall runs prisma generate)
RUN npm ci

# Copy source and build
COPY . .

# Build-time environment variable for VNC URL
ARG NEXT_PUBLIC_VNC_URL=https://lp-worker.jollyhill-e873fff9.eastus2.azurecontainerapps.io
ENV NEXT_PUBLIC_VNC_URL=$NEXT_PUBLIC_VNC_URL

RUN npm run build

ENV NODE_ENV=production
EXPOSE 3000

CMD ["npm", "start"]
